# Shared local service credentials.
# Copy to trading-cli-bot/.env and keep that file out of git.
#
# Recommended exchange-side permissions:
# - MarketData Gateway hosted keys should be read-only/public-data oriented when possible.
# - Trading Gateway keys should enable only the spot/swap trading permissions needed for smoke tests.
# - Disable withdrawal permission for all service keys.
# - Add IP whitelist where the exchange supports it.

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=

# OKX
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSWORD=

# Gate
GATE_API_KEY=
GATE_API_SECRET=
GATE_PASSWORD=

# MEXC
MEXC_API_KEY=
MEXC_API_SECRET=
MEXC_PASSWORD=

# Hosted MarketData Gateway security
# local-only for localhost development; auth-enabled for any public/network deployment.
MARKETDATA_GATEWAY_SECURITY_MODE=local-only
MARKETDATA_GATEWAY_CORS_ORIGINS=

# Server-side token registry. Store SHA-256 hashes, never raw tokens.
# Format: token_id,sha256_hex,scope1|scope2,expires_at_iso,rate_limit_per_minute
MARKETDATA_GATEWAY_AUTH_TOKEN_HASHES=
MARKETDATA_GATEWAY_AUTH_TOKENS_FILE=
MARKETDATA_GATEWAY_SECRET_PROVIDER=env
